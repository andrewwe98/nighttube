{
  "name": "youtube-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build",
    "start": "npx serve@latest out",
    "serve": "npx serve@latest out",
